{
  "protocol_version": "1.0",
  "baud_rate": 115200,
  "command_format": "CMD:VAL1:VAL2\\n",
  "commands": [
    {
      "id": "motor_drive",
      "uart_command": "M:L1:L2:R1:R2",
      "uart_example": "M:100:100:100:100",
      "python_method": "robot.drive(l1, l2, r1, r2)",
      "description": "Drive 4 mecanum motors. Values range -255 to 255. Positive = forward.",
      "parameters": [
        { "name": "l1", "type": "int", "range": [-255, 255], "description": "Left-front motor speed" },
        { "name": "l2", "type": "int", "range": [-255, 255], "description": "Left-rear motor speed" },
        { "name": "r1", "type": "int", "range": [-255, 255], "description": "Right-front motor speed" },
        { "name": "r2", "type": "int", "range": [-255, 255], "description": "Right-rear motor speed" }
      ]
    },
    {
      "id": "servo_set",
      "uart_command": "S:ANGLE",
      "uart_example": "S:90",
      "python_method": "robot.set_servo(angle)",
      "description": "Set the ultrasonic sensor servo to a specific angle.",
      "parameters": [
        { "name": "angle", "type": "int", "range": [0, 180], "description": "Servo angle in degrees" }
      ]
    },
    {
      "id": "distance_read",
      "uart_command": "D:?",
      "uart_example": "D:?",
      "python_method": "robot.read_distance()",
      "description": "Request ultrasonic distance reading. Returns distance in cm over serial.",
      "parameters": [],
      "returns": { "type": "float", "unit": "cm", "description": "Distance to nearest obstacle" }
    },
    {
      "id": "imu_read",
      "uart_command": "I:?",
      "uart_example": "I:?",
      "python_method": "robot.read_imu()",
      "description": "Request IMU data from the Micro:bit. Returns pitch, roll, heading.",
      "parameters": [],
      "returns": { "type": "dict", "fields": ["pitch", "roll", "heading"], "description": "IMU orientation data in degrees" }
    },
    {
      "id": "led_display",
      "uart_command": "L:TEXT",
      "uart_example": "L:HELLO",
      "python_method": "robot.display_text(text)",
      "description": "Scroll text on the Micro:bit 5×5 LED matrix.",
      "parameters": [
        { "name": "text", "type": "str", "description": "Text to scroll on the LED display" }
      ]
    },
    {
      "id": "buzzer_tone",
      "uart_command": "B:TONE",
      "uart_example": "B:440",
      "python_method": "robot.play_tone(freq)",
      "description": "Play a tone at the specified frequency through the buzzer.",
      "parameters": [
        { "name": "freq", "type": "int", "unit": "Hz", "description": "Tone frequency in Hertz" }
      ]
    },
    {
      "id": "emergency_stop",
      "uart_command": "M:0:0:0:0",
      "uart_example": "M:0:0:0:0",
      "python_method": "robot.stop()",
      "description": "Emergency all-stop. Sets all motor speeds to zero immediately.",
      "parameters": []
    }
  ]
}
